#include <iostream>
#include<bits/stdc++.h>
using namespace std;

int X[4] = {1,-1,0,0}, Y[4] = {0,0,1,-1};

bool dfs(vector<vector<char>>& mat, unordered_set<int>& vis, string& s, int k, int i, int j){
    if(k == s.size())
        return true;
    if(s[k] != mat[i][j])
        return false;
    if(k == s.size()-1)
        return true;
    int n = mat.size(), m = mat[0].size();
    vis.insert(i*n+j);
    for(int ind=0;ind<4;ind++){
        if(i+X[ind]>=0 and i+X[ind]<n and j+Y[ind]>=0 and j+Y[ind]<m and vis.find((i+X[ind])*n+j+Y[ind]) == vis.end()){
            if(dfs(mat,vis,s,k+1,i+X[ind],j+Y[ind]))
                return true;
        }
    }
    vis.erase(i*n+j);
    return false;
}

int main() {
    string s = "ama";
    vector<vector<char>> mat{{'n','a','m','a','n'}};
    int n = mat.size(), m = mat[0].size();
    unordered_set<int> vis; //store the index of the visited cell
    for(int i=0;i<n;i++){
        for(int j=0;j<m;j++){
            if(dfs(mat,vis,s,0,i,j)){
                cout<<"pass\n";
                return 0;
            }
        }
    }
    cout<<"fail\n";
    return 0;
}
