class Node{
    size_t count, id;
    public: Node(size_t count, size_t id)
    :count(count)
    ,id(id)
    {}
    size_t getCount()const{
        return count;
    }
    void setCount(size_t count){
        this->count = count;
    }
    size_t getID()const{
        return id;
    }
    bool operator<(const Node& other)const{
        return count > other.count;
    }
    bool operator==(const Node& other)const{
        return (count==other.count and id==other.id);
    }
};

class PopularityTracker {
    public:
     void increasePopularity(size_t id){
        managePopularity(id, INCREMENT);
     }
     void decreasePopularity(int id){
        managePopularity(id, DECREMENT);
     }
     int mostPopular(){
        auto it = sortedSet.begin();
        if(it->getCount() <= 0)
            return -1;
        return it->getID();
     }
     private:
     unordered_map<size_t,size_t> mapVotes;
     multiset<Node> sortedSet;
     enum Operation{
        INCREMENT,
        DECREMENT
     };
     void managePopularity(size_t id, Operation op){
        size_t currCount = (mapVotes.find(id) == mapVotes.end()) ? -1 : mapVotes[id];
        if(currCount == -1){
            if(op == INCREMENT)
                mapVotes[id] = 1;
            else
                return;
        }
        else{
            if(op == INCREMENT)
                mapVotes[id]++;
            else
                mapVotes[id]--;
            sortedSet.erase({currCount,id});
        }
        cout<<id<<","<<mapVotes[id]<<endl;
        sortedSet.insert({mapVotes[id],id});
     }
};

int main() {
